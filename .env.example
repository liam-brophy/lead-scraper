# Postgres connection string. On Railway, linking the Postgres addon to this
# service injects DATABASE_URL automatically -- you shouldn't need to set it by hand.
# For local dev: `docker compose up -d` then use the value below, or `railway run` to
# borrow the cloud value.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leads

# Google Places API key. Required for `scrape-local` / POST /api/scrape/local
# and the automated local-business scrape in scheduler.js.
# Uses Places API (New) -- in Google Cloud Console, enable "Places API (New)"
# specifically (APIs & Services > Library > search "Places API (New)" > Enable).
# The old "Places API" (legacy) is a different product and enabling that one
# instead will fail with PERMISSION_DENIED even with a valid key.
GOOGLE_PLACES_API_KEY=

# Dashboard login. Pick a real password before deploying -- this gates the only
# auth on a tool that will be reachable at a public URL.
DASHBOARD_PASSWORD=change-me

# Random secret used to sign the auth cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-too

# On Railway, set this explicitly and make sure `railway domain` targets the same
# port (--port 3000). Railway assigns its own PORT dynamically per deploy if you
# don't pin one, which silently breaks a domain created for a different port
# (learned the hard way: first deploy bound :8080, domain was pointed at :3000 -> 502).
PORT=3000
